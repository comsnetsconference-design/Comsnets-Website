rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. PUBLIC COLLECTIONS: Allow anyone to READ, but only Admin to WRITE
    match /organizing_committee/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /speakers/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /sponsored_events/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. DEFAULT SECURITY: Lock down anything else by default
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
